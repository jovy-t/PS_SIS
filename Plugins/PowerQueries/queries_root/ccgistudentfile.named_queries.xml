# PowerQueries for CCGI Files

<queries>
  <query
      name="com.cabrillo.powerschool.ccgi.student_file"
      coreTable="students"
      flattened="true"
      tags="students,state_reporting,california">

    <summary>CCGI Student File Extract</summary>
    <description>
      Returns active/inactive enrolled high school students for selected schools,
      including GPA, race pivot, ELA status, student email, and CA extension fields.
      Output aliases match the CCGI Student Data Element Template field names.
      Supports district_cds and gpa_type as runtime arguments.
    </description>

    <args>
        <arg name="district_cds"
            required="true"
            type="primitive"
            description="District CDS code"
            column="STUDENTS.DCID" />

        <arg name="gpa_type"
            required="true"
            type="primitive"
            description="Allowed values: Weighted, Unweighted, College, Other"
            default="Weighted"
            casing="upper"
            column="CLASSRANK.GPAMETHOD" />
    </args>

    <columns>
        <column column="STUDENTS.ID">PrimaryCDSCode</column>
        <column column="STUDENTS.STUDENT_NUMBER">LocalStudentID</column>
        <column column="STUDENTS.STATE_STUDENTNUMBER">StateID</column>

        <column column="STUDENTS.FIRST_NAME">FirstName</column>
        <column column="STUDENTS.FIRST_NAME">PreferredFirstName</column>
        <column column="STUDENTS.MIDDLE_NAME">MiddleName</column>
        <column column="STUDENTS.MIDDLE_NAME">PreferredMiddleName</column>
        <column column="STUDENTS.LAST_NAME">LastName</column>
        <column column="STUDENTS.LAST_NAME">PreferredLastName</column>
        <column column="STUDENTS.LAST_NAME">Suffix</column>

        <column column="STUDENTS.DOB">DateOfBirth</column>
        <column column="STUDENTS.GENDER">Gender</column>
        <column column="STUDENTS.GRADE_LEVEL">GradeLevel</column>
        <column column="CLASSRANK.GPA">GPA</column>
        <column column="CLASSRANK.GPAMETHOD">GPAType</column>
        <column column="STUDENTS.ID">CalGrantGPA</column>
        <column column="STUDENTS.ID">NSLP</column>

        <column column="S_CA_STU_X.LOTECERT">LOTECert</column>
        <column column="S_CA_STU_X.LOTECERTSOURCE">LOTECertSource</column>
        <column column="S_CA_STU_X.LOTECODE">LanguageCode</column>

        <column column="S_CA_STU_X.FOSTERPROGRAM">FosterYouth</column>
        <column column="STUDENTS.ID">ParentConsent</column>
        <column column="STUDENTS.FEDETHNICITY">HispanicEthnicity</column>

        <column column="STUDENTRACE.RACECD">RaceCode1</column>
        <column column="STUDENTRACE.RACECD">RaceCode2</column>
        <column column="STUDENTRACE.RACECD">RaceCode3</column>
        <column column="STUDENTRACE.RACECD">RaceCode4</column>
        <column column="STUDENTRACE.RACECD">RaceCode5</column>

        <column column="STUDENTS.ENTRYDATE">EnrollmentStartDate</column>
        <column column="STUDENTS.EXITDATE">EnrollmentEndDate</column>

        <column column="PSM_STUDENTCONTACT.EMAIL">DistrictAssignedStudentEmailAddress</column>

        <column column="S_CA_STU_X.SWDINDICATOR">SWDIndicator</column>
        <column column="S_CA_STU_X.PROGRAM504INDICATOR">504ProgramIndicator</column>
        <column column="S_CA_STU_ELA_C.ELASTATUS">EL</column>
        <column column="S_CA_STU_X.AB469OPTOUT">AB469OptOut</column>
        <column column="S_CA_STU_X.HOMELESS">Homeless</column>
        <column column="S_CA_STU_X.MIGRANTED">Migrant</column>
        <column column="S_CA_STU_X.PARENTED">ParentGuardianEdLevel</column>
    </columns>

    <sql><![CDATA[
WITH race_ranked AS (
    SELECT
        sr.studentid,
        TRIM(sr.racecd) AS racecd,
        ROW_NUMBER() OVER (
            PARTITION BY sr.studentid
            ORDER BY sr.racecd
        ) AS rn
    FROM studentrace sr
),

race_pivot AS (
    SELECT
        studentid,
        MAX(CASE WHEN rn = 1 THEN racecd END) AS racecode1,
        MAX(CASE WHEN rn = 2 THEN racecd END) AS racecode2,
        MAX(CASE WHEN rn = 3 THEN racecd END) AS racecode3,
        MAX(CASE WHEN rn = 4 THEN racecd END) AS racecode4,
        MAX(CASE WHEN rn = 5 THEN racecd END) AS racecode5
    FROM race_ranked
    GROUP BY studentid
),

gpa_data AS (
    SELECT
        cr.studentid,
        cr.schoolid,
        cr.gpamethod,
        cr.gpa,
        cr.yearid,
        cr.grade_level,
        cr.dcid,
        ROW_NUMBER() OVER (
            PARTITION BY cr.studentid, cr.schoolid
            ORDER BY
                cr.yearid DESC NULLS LAST,
                cr.grade_level DESC NULLS LAST,
                cr.dateranked DESC NULLS LAST,
                cr.dcid DESC
        ) AS rn
    FROM classrank cr
    WHERE UPPER(TRIM(cr.gpamethod)) =
        CASE UPPER(TRIM(:gpa_type))
            WHEN 'WEIGHTED' THEN 'WEIGHTED'
            WHEN 'UNWEIGHTED' THEN 'UNWEIGHTED'
            WHEN 'COLLEGE' THEN '10-12 UC/CSU A-G'
            WHEN 'OTHER' THEN 'CUMULATIVE'
        END
),

gpa_final AS (
    SELECT
        studentid,
        schoolid,
        gpamethod,
        gpa,
        yearid,
        grade_level,
        dcid
    FROM gpa_data
    WHERE rn = 1
),

ela_data AS (
    SELECT
        ela.studentsdcid,
        ela.elastatus,
        ela.elastatusstartdate,
        ela.elastatusenddate,
        ROW_NUMBER() OVER (
            PARTITION BY ela.studentsdcid
            ORDER BY
                ela.elastatusstartdate DESC NULLS LAST,
                ela.elastatusenddate DESC NULLS LAST,
                ela.id DESC
        ) AS rn
    FROM s_ca_stu_ela_c ela
    WHERE NVL(ela.excludefromstatereporting, 0) = 0
),

ela_final AS (
    SELECT
        studentsdcid,
        elastatus,
        elastatusstartdate,
        elastatusenddate
    FROM ela_data
    WHERE rn = 1
),

student_email AS (
    SELECT
        psc.studentid,
        TRIM(psc.email) AS email,
        ROW_NUMBER() OVER (
            PARTITION BY psc.studentid
            ORDER BY psc.id DESC
        ) AS rn
    FROM psm_studentcontact psc
    WHERE psc.email IS NOT NULL
      AND TRIM(psc.email) IS NOT NULL
),

student_email_final AS (
    SELECT
        studentid,
        email
    FROM student_email
    WHERE rn = 1
)

SELECT
    :district_cds || LPAD(TO_CHAR(sch.school_number), 7, '0') AS PrimaryCDSCode,
    TO_CHAR(stu.student_number) AS LocalStudentID,
    LPAD(TRIM(TO_CHAR(stu.state_studentnumber)), 10, '0') AS StateID,

    stu.first_name AS FirstName,
    NULL AS PreferredFirstName,
    stu.middle_name AS MiddleName,
    NULL AS PreferredMiddleName,
    stu.last_name AS LastName,
    NULL AS PreferredLastName,
    NULL AS Suffix,

    TO_CHAR(stu.dob, 'MM/DD/YYYY') AS DateOfBirth,

    CASE
        WHEN stu.gender IN ('M', 'F', 'X') THEN stu.gender
        ELSE NULL
    END AS Gender,

    LPAD(TO_CHAR(stu.grade_level), 2, '0') AS GradeLevel,

    CASE
        WHEN gd.gpa IS NOT NULL
         AND REGEXP_LIKE(TRIM(gd.gpa), '^[0-9]+(\.[0-9]+)?$')
            THEN TO_CHAR(ROUND(TO_NUMBER(TRIM(gd.gpa)), 2), 'FM9999990.00')
        ELSE '0.00'
    END AS GPA,

    LOWER(:gpa_type) AS GPAType,

    NULL AS CalGrantGPA,
    NULL AS NSLP,

    CASE
        WHEN TRIM(scx.lotecert) IN ('Y', 'N') THEN TRIM(scx.lotecert)
        ELSE NULL
    END AS LOTECert,

    NULLIF(TRIM(scx.lotecertsource), '') AS LOTECertSource,
    NULLIF(TRIM(scx.lotecode), '') AS LanguageCode,

    CASE
        WHEN scx.fosterprogram = 1 THEN 'Y'
        ELSE NULL
    END AS FosterYouth,

    NULL AS ParentConsent,

    CASE
        WHEN stu.fedethnicity = 1 THEN 'Y'
        ELSE NULL
    END AS HispanicEthnicity,

    rp.racecode1 AS RaceCode1,
    rp.racecode2 AS RaceCode2,
    rp.racecode3 AS RaceCode3,
    rp.racecode4 AS RaceCode4,
    rp.racecode5 AS RaceCode5,

    TO_CHAR(stu.entrydate, 'MM/DD/YYYY') AS EnrollmentStartDate,
    TO_CHAR(stu.exitdate, 'MM/DD/YYYY') AS EnrollmentEndDate,

    se.email AS DistrictAssignedStudentEmailAddress,

    CASE
        WHEN TRIM(scx.swdindicator) = 'Y' THEN 'Y'
        ELSE NULL
    END AS SWDIndicator,

    CASE
        WHEN TRIM(scx.program504indicator) = 'Y' THEN 'Y'
        ELSE NULL
    END AS "504ProgramIndicator",

    CASE
        WHEN TRIM(ed.elastatus) = 'EL' THEN 'Y'
        ELSE NULL
    END AS EL,

    CASE
        WHEN TRIM(scx.ab469optout) = 'Y' THEN 'Y'
        ELSE NULL
    END AS AB469OptOut,

    CASE
        WHEN TRIM(scx.homeless) = 'Y' THEN 'Y'
        ELSE NULL
    END AS Homeless,

    CASE
        WHEN scx.migranted = 1 THEN 'Y'
        ELSE NULL
    END AS Migrant,

    CASE
        WHEN TRIM(scx.parented) IN ('10', '11', '12', '13', '14', '15')
            THEN TRIM(scx.parented)
        ELSE NULL
    END AS ParentGuardianEdLevel

FROM students stu
JOIN schools sch
    ON sch.school_number = stu.schoolid
LEFT JOIN race_pivot rp
    ON rp.studentid = stu.id
LEFT JOIN gpa_final gd
    ON gd.studentid = stu.id
   AND gd.schoolid = stu.schoolid
LEFT JOIN s_ca_stu_x scx
    ON scx.studentsdcid = stu.dcid
LEFT JOIN ela_final ed
    ON ed.studentsdcid = stu.dcid
LEFT JOIN student_email_final se
    ON se.studentid = stu.id

WHERE stu.schoolid IN (4130027, 4132817)
  AND stu.enroll_status IN (-1, 0)
  AND stu.grade_level BETWEEN 9 AND 12
  AND stu.state_studentnumber IS NOT NULL

ORDER BY
    sch.school_number,
    stu.grade_level,
    stu.last_name,
    stu.first_name
    ]]></sql>
  </query>
</queries>